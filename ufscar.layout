#% Do not delete the line below; configure depends on this
# \DeclareLaTeXClass[ufscar]{UFSCar template}
# \DeclareLyxModule{Universidade}

# Author : Katia Poloni
# Fixed for English ufscar class commands and arguments

Format 35
Input stdclass.inc

Style Standard
	Category              MainText
	Margin                Static
	LatexType             Paragraph
	LatexName             dummy
	ParIndent             MM
	Parsep                0.4
	Spacing               onehalf
	Align                 Block
	AlignPossible         Block, Left, Right, Center
	LabelType             No_Label
End

Style Bibliography
	TopSep                4
	LabelString           "Bibliography"
	LabelFont
	  Series              Bold
	  Size                Huge
	EndFont
End

Style Title
	Margin                Static
	LatexType             Command
	Category              FrontMatter 
	InTitle               1
	LatexName             settitle
	ParSkip               0.4
	ItemSep               0
	TopSep                1.3
	BottomSep             1
	ParSep                1
	Align                 Center
	LabelType             No_Label
	Font
	  Size                Largest
	EndFont
End

Style Author
	Margin                Static
	LatexType             Command
	Category              FrontMatter
	InTitle               1
	LatexName             setauthor
	Argument 1
		Mandatory 1
		LabelString "Author Name(s)"
	EndArgument
	LabelSep              xxx
	ParSkip               0.4
	TopSep                1.3
	BottomSep             0.7
	ParSep                0.7
	Align                 Center
	LabelType             No_Label
	Font
	  Size                Large
	EndFont
End

Style Local
	Margin                Static
	LatexType             Command
	Category              FrontMatter
	InTitle               1
	LatexName             setplace
	LabelSep              xxx
	ParSkip               0.4
	TopSep                0.9
	BottomSep             0.5
	ParSep                1
	Align                 Center
	LabelType             No_Label
	Font
	  Size                Large
	EndFont
End

Style Date
	Margin                Static
	LatexType             Command
	Category              FrontMatter
	InPreamble            1
	InTitle               1
	LatexName             setyear
	LabelSep              xxx
	ParSkip               0.4
	TopSep                0.9
	BottomSep             0.5
	ParSep                1
	Align                 Center
	LabelType             No_Label
	Font
	  Size                Large
	EndFont
End

Style Orientador
	LatexType   Command
	LatexName   setadvisor
	Category    FrontMatter
	InTitle     1
	LabelType   Static
	LabelString "Advisor: "
	Align       Center
	Font
	  Size      Large
	EndFont
	LabelFont
	  Color     Green
	  Size      normal
	EndFont
End

Style "Co-orientador"
	CopyStyle   Orientador
	LatexName   setcoadvisor
	LabelString "Co-advisor: "
End

Style Universidade
	CopyStyle   Orientador
	Category    Universidade
	LatexName   setuniversity
	LabelString "University (Sigla is main text): "
	Argument 1
		Mandatory 1
		LabelString "Full University Name"
	EndArgument
End

Style Centro
	CopyStyle   Universidade
	LatexName   setcenter
	LabelString "Center (Sigla is main text): "
	Argument 1
		Mandatory 1
		LabelString "Full Center Name"
	EndArgument
End

Style Departamento
	CopyStyle   Universidade
	LatexName   setdepartment   
	LabelString "Department (Sigla is main text): "
	Argument 1
		Mandatory 1
		LabelString "Full Department Name"
	EndArgument
End

Style Programa
	CopyStyle   Universidade
	LatexName   setprogram
	LabelString "Program (Sigla is main text): "
	Argument 1
		Mandatory 1
		LabelString "Full Program Name"
	EndArgument
End

Style Curso
	CopyStyle   Orientador
	LatexName   setcourse
	LabelString "Course: "
End

Style "Area de Concentracao"
	CopyStyle   Orientador
	LatexName   setarea
	LabelString "Concentration Area: "
End

Style Dedicatoria
	LatexType   Command
	LatexName   imprimirdedicatoria
	Category    FrontMatter
	LabelType   Top_Environment
	LabelString "Dedicatoria"
	Align       left
	Margin      Dynamic
	TopSep      0.9
	BottomSep   0.5
	LabelFont
	  Size      large
	  Series    Bold
	EndFont
End

Style Resumo
	Margin      Dynamic
	LatexType   Environment
	LatexName   resumo
	Category    FrontMatter
	TopSep      0.9
	BottomSep   0.5
	LabelType   Centered_Top_Environment
	LabelString "Resumo"
	Argument 1
		Mandatory 1
		LabelString "Palavras-chave"
	EndArgument
	LabelFont
	  Size      larger
	  Series    Bold
	EndFont
End

Style Abstract
	CopyStyle     Resumo
	LatexName     abstract
	LabelString   "Abstract"
	Argument 1
		Mandatory 1
		LabelString "Keywords"
	EndArgument
End

Style Agradecimentos
	Margin      Dynamic
	LatexType   Command
	LatexName   imprimiragradecimentos
	Category    FrontMatter
	TopSep      0.9
	BottomSep   0.5
	LabelType   Top_Environment
	LabelString "Agradecimentos"
	LabelFont
	  Size      larger
	  Series    Bold
	EndFont
End

Style Epigrafe
	LatexType   Command
	LatexName   imprimirepigrafe
	Category    FrontMatter
	Align       Right
	Margin      Dynamic
	LabelString "Epigrafe"
	LabelType   Top_Environment
	TopSep      0.9
	BottomSep   0.5
	LabelFont
	  Series    Bold
	RightMargin "MMM"
End

Style "Resumo_capitulo"
	LatexType   Command
	LatexName   chapterprecishere
	Category    Sectioning
	LeftMargin  "MMMM"
	ParIndent   "0"
	RightMargin "MMMM"
	Font
		Shape   Italic
		Size    Normal
	EndFont
End

Style "Resumo_capitulo_sumario"
	LatexType   Command
	LatexName   chapterprecis
	Category    Sectioning
	LeftMargin  "MMMM"
	ParIndent   "0"
	RightMargin "MMMM"
	Font
		Shape   Italic
		Size    Normal
	EndFont
End

Style "Citacao direta"
	LatexType   Environment
	LatexName   citacao
	Category    MainText
	Align       Right
	LeftMargin  "MMMMMMMM"
	ParIndent   "0"
	RightMargin "MMMM"
	Font
		Size    Small
	EndFont
End

# -----------------------------------------
# Structural and List Commands
# -----------------------------------------

InsetLayout "Flex:Table of Contents*"
	LyXType	custom
	Decoration	classic
	LabelString	"Table of Contents*"
	ContentAsLabel	true
	LatexName	sumario
	LatexType	command
	MultiPar	false
	CustomPars	false
	ForcePlain	true
	PassThru	false
	FreeSpacing	true
	ParbreakIsNewline true
	ForceLTR	true
	Font
	  Family	Typewriter
	  Color	black
	EndFont
	BgColor	gray
	LabelFont
	  Family	Typewriter
	  Color	black
	  Size	Small
	EndFont
	HTMLIsBlock	false
End

InsetLayout "Flex:List of Figures*"
	LyXType	custom
	Decoration	classic
	LabelString	"List of Figures*"
	ContentAsLabel	true
	LatexName	listillustrations
	LatexType	command
	MultiPar	false
	CustomPars	false
	ForcePlain	true
	PassThru	false
	FreeSpacing	true
	ParbreakIsNewline true
	ForceLTR	true
	Font
	  Family	Typewriter
	  Color	black
	EndFont
	BgColor	white
	LabelFont
	  Family	Typewriter
	  Color	black
	  Size	Small
	EndFont
	HTMLIsBlock	false
End

InsetLayout "Flex:List of Tables*"
	LyXType	custom
	Decoration	classic
	LabelString	"List of Tables*"
	ContentAsLabel	true
	LatexName	listtables
	LatexType	command
	MultiPar	false
	CustomPars	false
	ForcePlain	true
	PassThru	false
	FreeSpacing	true
	ParbreakIsNewline true
	ForceLTR	true
	Font
	  Family	Typewriter
	  Color	black
	EndFont
	BgColor	white
	LabelFont
	  Family	Typewriter
	  Color	black
	  Size	Small
	EndFont
	HTMLIsBlock	false
End

InsetLayout "Flex:Lista de Siglas"
	LyXType	custom
	Decoration	classic
	LabelString	"List of Acronyms"
	ContentAsLabel	false
	LatexName	listasiglas
	LatexType	command
	MultiPar	false
	CustomPars	false
	ForcePlain	true
	PassThru	false
	FreeSpacing	true
	ParbreakIsNewline true
	ForceLTR	true
	Font
	  Family	Typewriter
	  Color	black
	EndFont
	BgColor	white
	LabelFont
	  Family	Typewriter
	  Color	black
	  Size	Small
	EndFont
	HTMLIsBlock	false
End

Style MainMatter
	Category	Sectioning
	Margin	Static
	LatexType	Command
	LatexName	mainmatter
	LabelType	Static
	LabelString	"------------------ Textual -----------------"
	KeepEmpty	true
	TopSep	1
	BottomSep	1
	Align	Center
	Font
	  Color	Blue
	  Series	Bold
	EndFont
End

Style PreTextual
	CopyStyle	MainMatter
	Category	FrontMatter
	LatexName	pretextual
	LabelString	"------------------ Pre-Textual -----------------"
End

Style PosTextual
	CopyStyle	MainMatter
	Category	BackMatter
	LatexName	postextual
	LabelString	"------------------ Pos-Textual -----------------"
End

# -----------------------------------------
# Maketitle, Glossary, and Bookmarksetup
# -----------------------------------------

InsetLayout "Flex:Make Title"
	LyXType	custom
	Decoration	classic
	LabelString	"Make Title"
	ContentAsLabel	true
	LatexName	maketitle
	LatexType	command
	MultiPar	false
	CustomPars	false
	ForcePlain	true
	PassThru	false
	FreeSpacing	true
	ParbreakIsNewline true
	ForceLTR	true
	Font
	  Family	Typewriter
	  Color	black
	EndFont
	BgColor	white
	LabelFont
	  Family	Typewriter
	  Color	black
	  Size	Small
	EndFont
	HTMLIsBlock	false
End

InsetLayout "Flex:Glossary"
	LyXType	custom
	Decoration	classic
	LabelString	"Glossary"
	ContentAsLabel	true
	LatexName	glossary
	LatexType	command
	MultiPar	false
	CustomPars	false
	ForcePlain	true
	PassThru	false
	FreeSpacing	true
	ParbreakIsNewline true
	ForceLTR	true
	Font
	  Family	Typewriter
	  Color	black
	EndFont
	BgColor	white
	LabelFont
	  Family	Typewriter
	  Color	black
	  Size	Small
	EndFont
	HTMLIsBlock	false
End

InsetLayout "Flex:Bookmark Setup"
	LyXType	custom
	Decoration	classic
	LabelString	"Bookmark Setup:"
	ContentAsLabel	false
	LatexName	bookmarksetup
	LatexType	command
	MultiPar	false
	CustomPars	false
	ForcePlain	true
	PassThru	false
	FreeSpacing	true
	ParbreakIsNewline true
	ForceLTR	true
	Font
	  Family	Typewriter
	  Color	black
	EndFont
	BgColor	white
	LabelFont
	  Family	Typewriter
	  Color	black
	  Size	Small
	EndFont
	HTMLIsBlock	false
End

Style Legend
	Category	MainText
	Margin	Static
	LatexType	Command
	LatexName	legend
	Align	Center
	LabelType	No_Label
	KeepEmpty	true
	Font
	  Size	Small
	EndFont
End